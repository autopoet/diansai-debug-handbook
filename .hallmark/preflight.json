  ],
  "constraints": [
    "不改变后端接口",
    "保留行内编辑、版本责任信息和审核 Diff",
    "不引入动效依赖",
    "支持 320、375、414、768 CSS 像素宽度",
    "尊重 prefers-reduced-motion"
