  "selectedSystem": {
    "theme": "studied-DNA (source: blog.autopoet.cn / autopoet-my-blog)",
    "navigation": "functional orbital floating navigation",
    "footer": "Ft2 Inline-rule single line",
    "pages": {
      "home": "Ecosystem Index",
      "explore": "Index-First",
