APP_ENVIRONMENT=development
APP_DATABASE_URL=postgresql://diansai:local-development-only@localhost:5432/diansai
APP_FRONTEND_ORIGIN=http://localhost:5173
APP_SESSION_COOKIE_NAME=diansai_session
APP_SESSION_DAYS=7
APP_SECURE_COOKIES=false
APP_FRONTEND_DIST=
APP_MAINTENANCE_READ_ONLY=false
APP_UPLOAD_DIR=data/uploads
APP_MAX_IMAGE_BYTES=10485760
APP_STORAGE_BACKEND=local
APP_SUPABASE_URL=
APP_SUPABASE_SECRET_KEY=
APP_SUPABASE_STORAGE_BUCKET=article-images

# 仅供 `python -m app.db.seed` 创建本地演示账号，不要用于线上环境。
APP_SEED_REVIEWER_USERNAME=demo_reviewer
APP_SEED_REVIEWER_PASSWORD=reviewer-local-123
APP_SEED_CONTRIBUTOR_USERNAME=demo_contributor
APP_SEED_CONTRIBUTOR_PASSWORD=contributor-local-123

# 不使用 PostgreSQL 时，可以临时切换到 SQLite：
# APP_DATABASE_URL=sqlite:///data/app.db
